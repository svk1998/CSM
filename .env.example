NODE_ENV=production
PORT=3000
HOST=0.0.0.0
TRUST_PROXY=loopback
COOKIE_SECURE=false
WORKSPACE_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
SESSION_SECRET=replace-with-a-random-32-character-secret
SESSION_MAX_AGE_HOURS=24

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=csmanager
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=csmanager
POSTGRES_SSL=false

DOCKER_SOCKET=/var/run/docker.sock
DOCKER_NETWORK_NAME=csm-network
WORKSPACE_PROXY_MODE=network
WORKSPACE_STORAGE_MODE=named-volume
WORKSPACE_BASE_PATH=/workspaces

CODE_SERVER_IMAGE=codercom/code-server:4.111.0
DEFAULT_CPU_SHARES=1024
DEFAULT_MEMORY_MB=2048
PORT_RANGE_START=10000
PORT_RANGE_END=10999
IDLE_TIMEOUT_MINUTES=60
CLEANUP_INTERVAL_MINUTES=10
CODE_SERVER_BOOT_TIMEOUT_MS=45000
LOG_LEVEL=info
